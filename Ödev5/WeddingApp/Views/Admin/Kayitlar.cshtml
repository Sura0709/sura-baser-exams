@model IEnumerable<WeddingApp.Models.RsvpResponse>

@{
    ViewData["Title"] = "Kayıtlar";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0" style="color: var(--wedding-gold);">Katılım Kayıtları</h2>
</div>

@if (!Model.Any())
{
    <div class="alert alert-light border">Henüz katılım bildirimi yok.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover bg-white rounded shadow-sm">
            <thead>
                <tr>
                    <th>Ad Soyad</th>
                    <th>E-posta</th>
                    <th>Telefon</th>
                    <th>Kişi</th>
                    <th>Yemek</th>
                    <th>Tarih</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var kayit in Model)
                {
                    <tr>
                        <td>@kayit.FirstName @kayit.LastName</td>
                        <td>@kayit.Email</td>
                        <td>@kayit.Phone</td>
                        <td>@kayit.GuestCount</td>
                        <td>@(kayit.WillAttendMeal == true ? "Katılacak" : "Katılmayacak")</td>
                        <td>@kayit.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
